// prisma/core.prisma
model Country {
  id           String           @id @default(uuid())
  code         String           @unique // e.g., "US", "DE", "BD"
  name         String
  currency     String           @default("USD")
  isActive     Boolean          @default(true)
  taxRules     TaxRule[]
  calculations TaxCalculation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}